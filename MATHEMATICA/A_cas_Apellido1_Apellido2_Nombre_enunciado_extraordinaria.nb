       {"\[Piecewise]", GridBox[{
          {
           SuperscriptBox["3", 
            RowBox[{"-", "x"}]], 
           RowBox[{"x", "\[LessEqual]", "0"}]},
          {
           SqrtBox[
            RowBox[{"x", "+", "1"}]], 
