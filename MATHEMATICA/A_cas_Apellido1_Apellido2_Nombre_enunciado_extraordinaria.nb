Cell[TextData[{
 "Sean los siguientes conjuntos:\n \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"E", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "\[Element]", 
       RowBox[{
        RowBox[{"\[DoubleStruckCapitalN]", "/", "x"}], " ", 
        "m\[UAcute]ltiplo", " ", "de", "  ", "3"}]}], " ", "\[And]", " ", 
      RowBox[{"100", "\[LessEqual]", "x", "\[LessEqual]", "200"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"36347366-b3d4-4bc7-ae36-19a4d9a72875"],
 "\n \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"A", "=", 
    RowBox[{"{", 
     RowBox[{"x", "\[Element]", 
      RowBox[{
       RowBox[{"E", "/", "x"}], " ", "es", " ", "m\[UAcute]ltiplo", " ", "de",
        " ", "6"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "d2f2c79f-8b1e-43ee-8338-f908f569d4af"],
 "\n \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x", "\[Element]", 
       RowBox[{
        RowBox[{"E", "/", "x"}], "  ", "impar"}]}], " ", "\[And]", " ", 
      RowBox[{"x", ">", "115"}]}], "}"}]}], TraditionalForm]],ExpressionUUID->
  "64a794e6-12fb-4b35-aad1-d1cfe4760173"],
 "\n \t",
 Cell[BoxData[
  FormBox[
   RowBox[{"C", "=", 
    RowBox[{"{", 
     RowBox[{"x", "\[Element]", 
      RowBox[{
       RowBox[{"E", "/", "110"}], "<", "x", "<", "150"}]}], "}"}]}], 
   TraditionalForm]],ExpressionUUID->"ab99c891-25ec-4063-a4b4-99f7674c762a"],
 "\n \t\n a) Define cada conjunto y calcula el n\[UAcute]mero de elementos de \
cada uno de ellos. "
}], "Subsection",
 CellChangeTimes->{{3.7854853538458905`*^9, 3.7854854274848337`*^9}, {
