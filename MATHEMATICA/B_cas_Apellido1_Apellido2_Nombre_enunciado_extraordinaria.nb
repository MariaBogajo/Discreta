    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{"ln", "(", 
            RowBox[{"1", "-", "x"}], ")"}], 
           RowBox[{"x", "\[LessEqual]", "0"}]},
          {
           SuperscriptBox["x", "3"], 
           RowBox[{"x", ">", "0"}]}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{
          "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, 
